// CodeArena — Database Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum Role {
  STUDENT
  STAFF
  ADMIN
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionType {
  CODING
  MCQ
  TRUE_FALSE
  MULTISELECT
  SQL
}

model Institute {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String?
  address   String?
  contact   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  // Certificate branding — stored as a data URL, same pattern as User.profilePhotoUrl (no
  // external object storage on this platform).
  logoUrl String?

  // Enterprise security config (Section 2 of the enterprise spec) — per-institute, so one
  // institute's stricter policy doesn't force it on every other institute sharing the platform.
  passwordExpiryDays   Int?     // null = passwords never expire
  passwordHistoryDepth Int      @default(3) // block reuse of this many previous passwords
  singleSessionOnly    Boolean  @default(false) // true = a new login revokes this account's other active sessions
  aiHintsEnabled        Boolean @default(false) // Learning Module coding hints — off by default, admin opt-in

  // Attendance Management: display-only warning threshold shown on a student's own attendance
  // view when their per-subject percentage falls below it. Null = no threshold configured, no
  // warning shown — this never blocks anything (tests, login, etc.), purely informational.
  attendanceMinPercent Int?

  classes         Class[]
  users           User[]
  questions       Question[]
  questionFolders QuestionFolder[]
  departments     Department[]
  academicGroups  AcademicGroup[]
}

model Class {
  id        String   @id @default(uuid())
  name      String // e.g. "MCA", "B.Tech CSE"
  code      String?
  batchYear String? // e.g. "2025" — nullable at the DB level (existing classes predate this field);
                     // required at the application layer for newly created classes
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  institute   Institute? @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  instituteId String?

  // Attendance Management's Department → Division hierarchy — nullable so every existing Class
  // row (and everything else that already reads Class: tests, learning, resume, etc.) keeps
  // working unchanged. A Class only becomes attendance-eligible once an admin assigns it into a
  // Division (see routes/attendance.js's admin division-assignment endpoint).
  division   Division? @relation(fields: [divisionId], references: [id])
  divisionId String?

  users           User[]
  testAssignments TestClass[]

  staffAssignments   StaffClassAssignment[]

  @@unique([instituteId, name, batchYear])
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(STUDENT)
  rollNumber   String?  // students only — a.k.a. College/Institute ID
  registrationNumber String? // students only — separate from rollNumber, e.g. university enrollment no.
  department   String?
  mobile       String?
  gender       String?  // optional, free-text
  program      String?  // free-text fallback if no Class relation is set
  batchYear    String?
  section      String?
  isActive     Boolean  @default(true) // false = account is deactivated; blocked at login
  profilePhotoUrl String? // optional; stored as a data URL, no external file storage in use
  mustChangePassword Boolean @default(false)
  passwordChangedAt  DateTime? // drives per-institute password-expiry enforcement
  createdAt    DateTime @default(now())

  institute   Institute? @relation(fields: [instituteId], references: [id])
  instituteId String?
  class       Class?     @relation(fields: [classId], references: [id])
  classId     String?

  // Institute -> Batch -> Department -> Section: replaces Class/classId as the platform's real
  // enrollment/grouping mechanism. classId above is kept populated for existing rows (rollback
  // safety net) but is no longer read by any new code once the cutover phases ship.
  academicGroup   AcademicGroup? @relation(fields: [academicGroupId], references: [id])
  academicGroupId String?

  resetTokenHash   String?
  resetTokenExpiry DateTime?

  createdTests Test[]         @relation("TestCreator")
  attempts     TestAttempt[]
  submissions  Submission[]
  createdQuestions Question[]

  lessonProgress LessonProgress[]
  certificates    Certificate[]
  practiceRunLogs PracticeRunLog[]
  codeDrafts      CodeDraft[]
  moduleCodingAttempts ModuleCodingAttempt[]
  xpEvents        XpEvent[]
  badges          StudentBadge[]
  streak          StudentStreak?
  resume          Resume?
  resumeFeedback  ResumeFeedback[]

  interviewSessions    InterviewSession[]
  interviewReports     InterviewReport[]
  interviewCertificate InterviewCertificate?
  emailLogs            EmailLog[]

  passwordHistory PasswordHistory[]
  loginSessions   LoginSession[]

  dailyChallengeSubmissions  DailyChallengeSubmission[]
  weeklyChallengeSubmissions WeeklyChallengeSubmission[]

  // Attendance Management — staff only: which classes this staff member has been assigned to
  // mark attendance for, and the plans/sessions/records that flow from that.
  staffClassAssignments    StaffClassAssignment[] @relation("StaffClassAssignments")
  lecturePlansCreated      LecturePlan[]          @relation("LecturePlanCreatedBy")
  attendanceSessionsMarked AttendanceSession[]    @relation("AttendanceMarkedBy")
  attendanceSessionsUpdated AttendanceSession[]   @relation("AttendanceUpdatedBy")
  attendanceRecords        AttendanceRecord[]     @relation("AttendanceStudentRecords")

  @@index([instituteId])
  @@index([classId])
  @@index([academicGroupId])
  @@index([role])
  @@index([department])
}

model Test {
  id           String   @id @default(uuid())
  title        String
  code         String?
  description  String?
  instructions String?
  durationMin  Int      @default(60)
  passingMarks Int?
  showResults  Boolean  @default(true)
  // Set only for a company-specific placement round (e.g. "TCS", "Amazon") — reuses this same
  // Test/TestTaking pipeline rather than a parallel one; null = a regular test, not company-tagged.
  company      String?
  startTime    DateTime
  endTime      DateTime
  isPublished  Boolean  @default(false)
  requireFullscreen Boolean @default(true)
  requireWebcam     Boolean @default(false) // best-effort face presence check, mirrors ModuleCodingTest
  requireMicrophone Boolean @default(false) // mic-drop is monitored/warned but never blocks Submit
  // Attendance Management integration: when true, this test only appears in the Attendance
  // module's Practice Test/Exam "Select Test" dropdown, and POST /:id/start blocks any student
  // who hasn't been marked Present for the lecture this test is linked to (see AttendanceSession).
  attendanceMandatory Boolean @default(false)
  shuffleQuestions  Boolean @default(true)  // each student gets a random per-attempt question order (same question set)
  shuffleOptions    Boolean @default(false) // each student also gets randomized MCQ/MULTISELECT option order
  // "FIXED" (default): every student gets the test's full configured question list (questions[]).
  // "RANDOM": every student gets a random randomQuestionsPerStudent-sized subset of the questions
  // in randomBankFolder, generated once at attempt start — see buildAttemptOrder() in tests.js.
  // In RANDOM mode, questions[] still holds every question in the bank (so admin edits/points/
  // time limits are managed the normal way); it's just never shown to a student in full.
  questionSelectionMode    String  @default("FIXED")
  randomBankFolder         QuestionFolder? @relation(fields: [randomBankFolderId], references: [id])
  randomBankFolderId       String?
  randomQuestionsPerStudent Int?
  difficultyDistribution   Json? // optional { easy, medium, hard } counts that must sum to randomQuestionsPerStudent
  createdBy    User     @relation("TestCreator", fields: [createdById], references: [id])
  createdById  String
  createdAt    DateTime @default(now())

  questions TestQuestion[]
  attempts  TestAttempt[]
  classes   TestClass[] // empty = open to all classes (legacy/unscoped tests)
  academicGroups TestAcademicGroup[] // replaces classes[] as the real eligibility gate — see testEligibility.js

  // Attendance Management: when Lecture Type = Exam, a session can link back to the Test being
  // administered, so exam attendance is tied to the actual test rather than duplicated.
  attendanceSessions AttendanceSession[]

  @@index([createdById])
  @@index([isPublished])
  @@index([startTime, endTime])
  @@index([company])
}

// Join table: which classes a test is assigned to — legacy, superseded by TestAcademicGroup below.
model TestClass {
  id      String @id @default(uuid())
  test    Test   @relation(fields: [testId], references: [id], onDelete: Cascade)
  testId  String
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId String

  @@unique([testId, classId])
}

// Join table: which academic groups (Institute+Batch+Department+Section) a test is assigned to.
// Empty = open to all groups (mirrors TestClass's "empty = open to all classes" convention).
model TestAcademicGroup {
  id              String        @id @default(uuid())
  test            Test          @relation(fields: [testId], references: [id], onDelete: Cascade)
  testId          String
  academicGroup   AcademicGroup @relation(fields: [academicGroupId], references: [id], onDelete: Cascade)
  academicGroupId String

  @@unique([testId, academicGroupId])
}

model Question {
  id             String       @id @default(uuid())
  questionNumber Int          @default(autoincrement()) @unique // human-friendly display ID, e.g. "Q102"
  title          String?      // question name (optional label)
  description    String       // question text
  subject        String?
  topic          String?
  questionType   QuestionType @default(CODING)
  difficulty     Difficulty   @default(EASY)
  points         Int          @default(10) // marks
  explanation    String?
  createdAt      DateTime     @default(now())

  // CODING-only fields
  timeLimitMs   Int     @default(2000)
  memoryLimitKb Int?    // null = use the judge's global default (JUDGE_MEMORY_LIMIT_KB)
  starterCode   String? // legacy single-language fallback, kept for old questions/callers
  starterCodeByLanguage Json? // { java, python, cpp, c, javascript } — preferred when present
  tags          Json?   // string[], e.g. ["Arrays","Dynamic Programming"]

  // "Professional structure" fields (LeetCode/HackerRank-style problem statement) — all optional
  // so existing/legacy questions render fine with these simply omitted. problemExplanation is
  // distinct from the pre-existing `explanation` field above, which is a staff-only note never
  // shown to students (see CreateQuestion.jsx) — this one IS shown to students, as a beginner-
  // friendly walkthrough of the problem, so the two must never be conflated.
  estimatedTimeMin  Int?
  realWorldScenario String?
  constraints       String?
  inputFormat       String?
  outputFormat      String?
  notes             String?
  edgeCases         String?
  problemExplanation String?

  // Editorial/hints block (CODING only) — deliberately excluded from the sanitizer used for
  // proctored Formal Tests and Module Coding Assessments (same treatment as hidden test cases),
  // so these only ever reach students in self-paced contexts (Practice, Interview Prep, Daily/
  // Weekly Challenge). ProblemStatement.jsx renders each section only when present, so omitting
  // them from a proctored payload is sufficient gating — no extra frontend logic needed.
  hints            Json?   // string[] — progressive hints, revealed one at a time by the student
  timeComplexity   String? // e.g. "O(n)"
  spaceComplexity  String? // e.g. "O(1)"
  editorial        Json?   // { bruteForce: {approach, complexity}, betterApproach: {...}, optimal: {...} }
  similarQuestions Json?   // string[] of related question titles — plain text, not a hard relation (spans multiple models)

  // "STDIO" (default): the student's submitted code IS the whole program — reads stdin, writes
  // stdout, same as it always has been. "FUNCTION": LeetCode-style — the student writes only a
  // method/function body matching functionSignature; the judge auto-generates the surrounding
  // driver (stdin parsing, method invocation, output formatting) at judge time — see
  // backend/src/utils/functionHarness.js. Only meaningful for CODING questions.
  evaluationType   String @default("STDIO")
  functionSignature Json? // { methodName, returnType, params: [{name, type}] } — see functionHarness.js SUPPORTED_TYPES

  // MCQ / TRUE_FALSE / MULTISELECT fields
  options       Json? // array of option strings
  correctAnswer Json? // array of correct option indices

  // SQL-only: DDL + seed data (CREATE TABLE ...; INSERT INTO ...;) run once against a fresh
  // in-memory SQLite database before each test case, shared across all of this question's cases.
  // A case's own TestCase.input is optional *additional* setup SQL run after this (e.g. extra
  // rows for that specific case — the LeetCode-SQL-problem pattern of varying the underlying
  // data per case while grading the same submitted query); TestCase.expected holds the
  // serialized expected result set. SQLite dialect only — see utils/sqlJudge.js.
  sqlSchema String?

  testCases TestCase[]
  testLinks TestQuestion[]
  dailyChallenges  DailyChallenge[]
  weeklyChallenges WeeklyChallenge[]

  // Set only when this question belongs to a Learning Module's proctored coding-test pool
  // (reusing this same Question/TestCase model — hidden test cases, judge grading — rather
  // than a separate coding_questions table, exactly like the exam side already does).
  moduleCodingTest   ModuleCodingTest? @relation(fields: [moduleCodingTestId], references: [id], onDelete: Cascade)
  moduleCodingTestId String?
  moduleAttemptLinks ModuleCodingAttemptQuestion[]

  // Institute-private question banks. Nullable, and deliberately NOT backfilled on migration —
  // every question created before this feature stays instituteId: null, which the visibility
  // rule (see questions.js's instituteVisibilityWhere) treats as "shared legacy bank, visible to
  // every institute" rather than "belongs to nobody." That's what keeps existing question banks
  // from silently disappearing for every institute's staff the moment this ships. Only questions
  // created going forward get scoped to their creator's institute and become genuinely private.
  institute   Institute? @relation(fields: [instituteId], references: [id], onDelete: SetNull)
  instituteId String?
  folder      QuestionFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  folderId    String?
  createdBy   User? @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdById String? // nullable — questions created before this field existed have no recorded author

  @@index([subject])
  @@index([topic])
  @@index([questionType])
  @@index([moduleCodingTestId])
  @@index([instituteId])
  @@index([folderId])
  @@index([createdById])
}

// A named grouping within an institute's question bank (e.g. "Java", "DBMS Midterm"), nestable
// (parent/children) so banks can be organized like "Fox Solutions > Aptitude > Percentages."
// Deletion requires the folder to be empty of both questions and child folders (see the DELETE
// route) — the previous "un-file on delete" behavior is replaced by an explicit block, per spec:
// admins move/merge first, then delete.
model QuestionFolder {
  id          String   @id @default(uuid())
  name        String
  category    String?  // free-text grouping label (e.g. "Aptitude", "Technical") shown alongside the name
  description String?
  institute   Institute? @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  instituteId String?    // null = platform-level folder, visible to every institute (Super Admin created)
  parent      QuestionFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  parentId    String?
  children    QuestionFolder[] @relation("FolderHierarchy")
  createdAt   DateTime @default(now())

  questions Question[]
  randomBankTests Test[]

  @@index([parentId])

  @@index([instituteId])
}

model TestCase {
  id          String   @id @default(uuid())
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionId  String
  input       String
  expected    String
  isHidden    Boolean  @default(true) // hidden test cases aren't shown to students
  explanation String?  // optional, sample cases only — shown alongside the case to help students understand it
}

// Join table: which questions belong to which test, in what order
model TestQuestion {
  id         String   @id @default(uuid())
  test       Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  testId     String
  question   Question @relation(fields: [questionId], references: [id])
  questionId String
  order      Int      @default(0)
  timeLimitSec Int    @default(900) // how long the student gets on this question within the test

  @@unique([testId, questionId])
}

model TestAttempt {
  id          String    @id @default(uuid())
  test        Test      @relation(fields: [testId], references: [id], onDelete: Cascade)
  testId      String
  student     User      @relation(fields: [studentId], references: [id])
  studentId   String
  startedAt   DateTime  @default(now())
  submittedAt DateTime?
  totalScore  Int       @default(0)
  status      String    @default("IN_PROGRESS") // IN_PROGRESS, SUBMITTED, AUTO_SUBMITTED
  tabSwitchCount Int    @default(0)

  // Generated once, at first attempt creation, from Test.shuffleQuestions/shuffleOptions — never
  // recomputed afterward, so a refresh, logout/login, or auto-save/recovery always sees the same
  // sequence. questionOrder: Question.id[] in this student's display order (equals the test's
  // configured order when shuffleQuestions is off). optionOrder: { [questionId]: number[] }, a
  // permutation of original option indices per MCQ/MULTISELECT/TRUE_FALSE question — populated
  // only when shuffleOptions is on.
  questionOrder Json?
  optionOrder   Json?

  submissions Submission[]

  @@unique([testId, studentId])
  @@index([testId])
}

model Submission {
  id           String      @id @default(uuid())
  attempt      TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  attemptId    String
  questionId   String
  student      User        @relation(fields: [studentId], references: [id])
  studentId    String
  language     String
  code         String
  score        Int         @default(0)
  passedCases  Int         @default(0)
  totalCases   Int         @default(0)
  verdict      String      @default("PENDING") // ACCEPTED, PARTIAL, WRONG_ANSWER, TLE, RUNTIME_ERROR, COMPILE_ERROR, PENDING
  timeMs       Int? // max execution time across judged test cases (coding only)
  memoryKb     Int? // max memory usage across judged test cases (coding only)
  createdAt    DateTime    @default(now())

  // One row per attempt+question — enforced at the DB level so autosave's upsert can never
  // race into two rows for the same question (which previously risked the grader picking the
  // wrong one). MCQ/TRUE_FALSE/MULTISELECT still get a fresh row per answer-change via
  // deleteMany+create, which also respects this constraint (at most one row survives).
  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
  @@index([studentId])
}

// Lightweight audit trail for sensitive admin actions (currently just reattempt grants).
model AuditLog {
  id          String   @id @default(uuid())
  action      String // e.g. "REATTEMPT_GRANTED", "LOGIN", "LOGOUT", "CERTIFICATE_ISSUED" — see
  // AUDIT_ACTIONS in utils/auditLog.js for the full catalogue this platform writes.
  adminId     String
  adminName   String
  adminRole   String? // denormalized at write time — Role enum value, nullable so pre-existing rows stay valid
  ipAddress   String?
  deviceInfo  String? // short summary, e.g. "Chrome on Windows" — parsed from User-Agent, not stored raw
  studentId   String? // the account acted on, when applicable — lets history views filter per-student
  instituteId String? // denormalized at write time from the acted-on student, so Staff can query
  // their own institute's history directly instead of joining through User for every row
  details     Json
  createdAt   DateTime @default(now())

  @@index([action])
  @@index([studentId])
  @@index([instituteId])
  @@index([createdAt])
}

model PasswordHistory {
  id           String   @id @default(uuid())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  passwordHash String
  createdAt    DateTime @default(now())

  @@index([userId])
}

// One row per login, kept through logout/expiry (isActive flips to false rather than the row
// being deleted) so "recent login history" stays queryable, not just the currently-active set.
model LoginSession {
  id        String    @id @default(uuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  token     String    @unique // the JWT's jti — lets a revoked session's token be rejected server-side
  ip        String?
  device    String?   // "Mobile" | "Tablet" | "Desktop", parsed from User-Agent
  browser   String?
  os        String?
  isActive  Boolean   @default(true)
  loginAt   DateTime  @default(now())
  logoutAt  DateTime?

  @@index([userId])
  @@index([userId, isActive])
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
  RETRYING
}

// One row per outbound transactional email (welcome/password-reset), so admins can see actual
// delivery status per student instead of trusting a fire-and-forget send. Written by
// utils/mailer.js's sendMailLogged() helper — never inferred from "the API call didn't throw".
model EmailLog {
  id              String      @id @default(uuid())
  student         User?       @relation(fields: [studentId], references: [id], onDelete: SetNull)
  studentId       String?
  recipientName   String
  recipientEmail  String
  emailType       String // "WELCOME" | "PASSWORD_RESET"
  status          EmailStatus @default(PENDING)
  errorMessage    String?
  messageId       String?
  retryCount      Int         @default(0)
  createdAt       DateTime    @default(now())
  sentAt          DateTime?

  @@index([status])
  @@index([studentId])
  @@index([createdAt])
}

// ===================================================================
// Learning Module (LMS) — self-paced course content, separate from the
// exam/TestAttempt world above. A Course (e.g. "java") holds ordered
// CourseModules, each holding ordered Lessons, each optionally holding
// ordered PracticeQuestions. Deliberately its own model family (not
// reusing Test/Question) since practice here has different semantics:
// untimed, unlimited retries, immediate feedback, no proctoring.
// ===================================================================

model Course {
  id          String   @id @default(uuid())
  slug        String   @unique // "java", "python", ...
  name        String
  description String?
  order       Int      @default(0)
  isActive    Boolean  @default(false) // false = shown as "Coming soon", not browsable
  createdAt   DateTime @default(now())

  modules      CourseModule[]
  certificates Certificate[]
}

model CourseModule {
  id          String   @id @default(uuid())
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId    String
  title       String
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  lessons Lesson[]
  codingTest ModuleCodingTest?

  @@unique([courseId, title])
  @@index([courseId])
}

model Lesson {
  id               String   @id @default(uuid())
  module           CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId         String
  title            String
  order            Int      @default(0)
  content          String?  // admin-authored HTML: explanation, examples, syntax, notes, best practices
  videoUrl         String?  // external link (e.g. YouTube) — no in-house video hosting
  pdfUrl           String?  // external link to a hosted PDF — no in-house file storage
  externalLinks    Json?    // [{ label, url }]
  estimatedMinutes Int      @default(10)
  // The gating practice test for its module — batch-submitted (not per-question), scored,
  // and required to pass before the next module unlocks. At most one per module in practice
  // (the last lesson), but not DB-enforced since nothing breaks if that changes.
  isModuleTest     Boolean  @default(false)
  createdAt        DateTime @default(now())

  progress  LessonProgress[]
  questions PracticeQuestion[]

  @@unique([moduleId, title])
  @@index([moduleId])
}

model LessonProgress {
  id          String    @id @default(uuid())
  student     User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId   String
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId    String
  status      String    @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, COMPLETED
  bookmarked  Boolean   @default(false)
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@unique([studentId, lessonId])
  @@index([studentId])
}

// type: MCQ, FILL_BLANK, CODING, DEBUG, OUTPUT_PREDICTION — DEBUG/OUTPUT_PREDICTION are
// graded the same way as MCQ (pick the right option from `options`), the distinct type is
// only used to vary the UI label/icon. FILL_BLANK is graded by trimmed case-insensitive
// string match against `correctAnswer`. CODING reuses the exam judge against `testCases`.
model PracticeQuestion {
  id            String   @id @default(uuid())
  lesson        Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId      String
  type          String
  title         String? // problem title, e.g. "Two Sum" — added for parity with Question, optional so existing rows (prompt-only) keep working
  prompt        String
  options       Json?
  correctAnswer Json?
  explanation   String?
  starterCode   String?
  starterCodeByLanguage Json? // { java, python, cpp, c, javascript } — preferred when present, same as Question
  testCases     Json? // CODING: [{input, expected, isHidden?}] — isHidden absent/false = sample case
  language      String?
  difficulty    Difficulty @default(EASY) // CODING only — drives the tiered solve-XP amount
  tags          Json?   // string[] — parity with Question.tags

  // LeetCode-style function-only submissions — same STDIO/FUNCTION split as Question, see
  // functionHarness.js. STDIO (default): student's code is the whole program. FUNCTION: student
  // writes only the method body matching functionSignature; judge.js auto-generates the driver.
  evaluationType    String @default("STDIO")
  functionSignature Json?

  // "Professional structure" fields — see the identically-named block on Question above for the
  // full rationale; kept in sync field-for-field so ProblemStatement.jsx can render either shape.
  estimatedTimeMin   Int?
  realWorldScenario  String?
  constraints        String?
  inputFormat        String?
  outputFormat       String?
  notes              String?
  edgeCases          String?
  problemExplanation String?

  // Editorial/hints block — see the identically-named block on Question above for the full
  // rationale; kept in sync field-for-field.
  hints            Json?
  timeComplexity   String?
  spaceComplexity  String?
  editorial        Json?
  similarQuestions Json?

  order         Int      @default(0)
  createdAt     DateTime @default(now())

  runLogs PracticeRunLog[]

  @@index([lessonId])
}

// One row per "Submit" click on a coding practice question (POST /learning/practice/:id/submit)
// — the only persisted trace of daily learning-module coding activity. "Run" (sample-case-only
// self-check) is deliberately not logged here, matching the Run/Submit split used everywhere else
// on the platform: Run is a free, unlimited, side-effect-free debugging aid, Submit is the real
// attempt. Powers the dashboard's coding-practice streak: any day with at least one row counts,
// regardless of verdict, since a streak should reward showing up and practicing, not just
// getting it right on the first try.
model PracticeRunLog {
  id         String   @id @default(uuid())
  student    User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId  String
  question   PracticeQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionId String
  verdict    String
  createdAt  DateTime @default(now())

  @@index([studentId, createdAt])
}

// Generic code-draft autosave for coding surfaces that have no natural "attempt" row to hang a
// draft off of (Practice Coding, Mock Interview coding questions) — Coding Tests and Module
// Coding Tests autosave onto their own Submission/attempt models instead and don't use this.
// contextType + contextId together identify what's being edited (e.g. "PRACTICE" + questionId,
// or "INTERVIEW" + "<sessionId>:<questionId>") without needing a dedicated FK per surface.
model CodeDraft {
  id          String   @id @default(uuid())
  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId   String
  contextType String
  contextId   String
  code        String
  language    String
  updatedAt   DateTime @updatedAt

  @@unique([studentId, contextType, contextId])
}

enum CertificateType {
  LEARNING_MODULE
  CODING_ASSESSMENT
  MANUAL
}

enum CertificateStatus {
  VALID
  REVOKED
}

// Unified certificate record covering Learning Module completion, passed Coding Assessments
// (Module Coding Tests), and manually-issued institute certificates (workshops/FDP/bootcamps/
// placement prep/etc, which have no underlying enrollment model on this platform — an admin or
// staff member fills in the program name by hand at issuance time). AI Mock Interview
// certificates stay on the separate InterviewCertificate model below (already has its own
// working QR/verify flow) — the student-facing "My Certificates" page reads both tables and
// presents them as one list rather than migrating working data into this one.
model Certificate {
  id              String            @id @default(uuid())
  certificateCode String            @unique // format: CA-<year>-<institute code>-<program code>-<sequence>
  type            CertificateType   @default(LEARNING_MODULE)
  student         User              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId       String
  course          Course?           @relation(fields: [courseId], references: [id], onDelete: Cascade) // LEARNING_MODULE only
  courseId        String?
  moduleCodingTestId String?        // CODING_ASSESSMENT only — denormalized, no FK (see AuditLog.adminId for the same pattern)
  title           String            // display name on the certificate PDF, populated for every type
  programName     String?           // MANUAL only — free text, e.g. "FDP: Advanced Java Workshop"
  status          CertificateStatus @default(VALID)
  revokedAt       DateTime?
  revokedByName   String?
  revokedReason   String?
  issuedByName    String?           // MANUAL only — which staff/admin issued it; null = system-issued
  issuedAt        DateTime          @default(now())

  @@unique([studentId, courseId])
  @@index([studentId])
  @@index([type])
  @@index([status])
}

// ===================================================================
// Mandatory Proctored Coding Test — gates progression between Learning
// Module modules. The spec names 8 tables (module_coding_tests,
// coding_questions, coding_submissions, coding_results, module_unlocks,
// proctoring_logs, webcam_snapshots, assessment_attempts), consolidated
// here into 6:
//   - coding_questions -> reuses Question/TestCase (adds a nullable
//     moduleCodingTestId), exactly like the exam side's hidden/public
//     test cases and judge grading — no separate question model needed.
//   - coding_results -> folded into ModuleCodingAttempt (score/passed
//     fields) rather than a separate 1:1 results table.
//   - module_unlocks -> NOT a table. Unlock state is computed on read by
//     getModuleLockMap (extended to also require a PASSED attempt when a
//     module has an active coding test configured), the same pattern
//     already used for lesson-completion-based locking — no cron, no
//     stale cache, no persisted state to keep in sync.
//   - webcam_snapshots -> NOT implemented. This platform has no object
//     storage (see Resume.photoUrl / Lesson.videoUrl comments); capturing
//     and storing periodic images isn't feasible here. Face-presence
//     detection (missing/multiple faces) is still implemented and logged
//     as a ProctoringViolation *event*, reusing the same blazeface
//     approach as the exam proctoring — it just never persists an image.
// A module with no ModuleCodingTest (or an inactive one) is ungated by
// this feature entirely — existing modules keep working exactly as
// before (lesson-completion locking only), so this is opt-in per module.
// ===================================================================

model ModuleCodingTest {
  id                 String   @id @default(uuid())
  module             CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId           String   @unique
  title              String   @default("Module Coding Assessment")
  instructions       String?
  allowedLanguages   Json     @default("[\"java\",\"python\",\"javascript\",\"c\",\"cpp\"]") // string[]
  questionCount      Int      @default(3) // how many questions are drawn from the pool per attempt
  randomizeQuestions Boolean  @default(true) // false = always the pool's first N by `order`, in order
  passingPercent     Int      @default(70)
  timeLimitMin       Int      @default(45)
  maxAttempts        Int?     // null = unlimited
  cooldownMinutes    Int      @default(0) // required wait after a failed attempt before retrying
  maxViolations      Int      @default(3) // proctoring violations before auto-submit
  requireFullscreen  Boolean  @default(true)
  requireWebcam      Boolean  @default(false) // best-effort face presence check, see note above
  requireMicrophone  Boolean  @default(false) // mirrors requireWebcam — mic-drop is monitored/warned but never blocks final Submit
  allowResume        Boolean  @default(true) // resume an IN_PROGRESS attempt after a browser crash/refresh
  isActive           Boolean  @default(true) // false = gate is skipped entirely, module ungated
  createdAt          DateTime @default(now())

  questions Question[]
  attempts  ModuleCodingAttempt[]
}

model ModuleCodingAttempt {
  id                 String   @id @default(uuid())
  moduleCodingTest   ModuleCodingTest @relation(fields: [moduleCodingTestId], references: [id], onDelete: Cascade)
  moduleCodingTestId String
  student            User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId          String
  attemptNumber      Int
  status             String   @default("IN_PROGRESS") // IN_PROGRESS, SUBMITTED, AUTO_SUBMITTED
  score              Int      @default(0) // 0-100 percent across the attempt's questions
  passed             Boolean  @default(false)
  violationCount     Int      @default(0)
  autoSubmitReason   String?  // e.g. "MAX_VIOLATIONS", "TIME_EXPIRED"
  startedAt          DateTime @default(now())
  submittedAt        DateTime?

  questions   ModuleCodingAttemptQuestion[]
  submissions ModuleCodingSubmission[]
  violations  ProctoringViolation[]

  @@index([moduleCodingTestId, studentId])
  @@index([studentId])
}

// Snapshot of which questions (and in what order) were drawn for this specific attempt — so a
// resumed attempt sees the same set it started with, regardless of later pool changes/randomization.
model ModuleCodingAttemptQuestion {
  id         String   @id @default(uuid())
  attempt    ModuleCodingAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  attemptId  String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionId String
  order      Int      @default(0)

  @@unique([attemptId, questionId])
  @@index([attemptId])
}

// Mirrors Submission (exam side) but scoped to a ModuleCodingAttempt instead of a TestAttempt —
// kept as a sibling model rather than widening Submission's required attemptId FK, so this
// feature can't regress the exam submission flow at all.
model ModuleCodingSubmission {
  id          String   @id @default(uuid())
  attempt     ModuleCodingAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  attemptId   String
  questionId  String
  studentId   String
  language    String
  code        String
  score       Int      @default(0)
  passedCases Int      @default(0)
  totalCases  Int      @default(0)
  verdict     String   @default("PENDING") // ACCEPTED, PARTIAL, WRONG_ANSWER, TLE, RUNTIME_ERROR, COMPILE_ERROR, PENDING
  timeMs      Int? // max execution time across judged test cases
  memoryKb    Int? // max memory usage across judged test cases
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // One row per attempt+question — same race-proofing as Submission above; autosave's upsert
  // relies on this so two near-simultaneous saves for the same question can never create
  // duplicate rows that the grader might then pick between arbitrarily.
  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
}

// Event-level proctoring log (unlike the exam side's single tabSwitchCount integer) — an admin
// can review exactly what happened and when, not just how many times.
model ProctoringViolation {
  id        String   @id @default(uuid())
  attempt   ModuleCodingAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  attemptId String
  type      String // TAB_SWITCH, FULLSCREEN_EXIT, COPY, PASTE, CUT, RIGHT_CLICK, DRAG_ATTEMPT, DEVTOOLS, REFRESH_ATTEMPT, MULTI_MONITOR, FACE_MISSING, MULTIPLE_FACES, CAMERA_DROPPED
  createdAt DateTime @default(now())

  @@index([attemptId, createdAt])
}

// ===================================================================
// Gamification — XP, levels, badges, streaks, leaderboards. Gamification
// starts counting from when this system was deployed; it does not
// retroactively backfill XP/badges for activity that already happened.
// ===================================================================

// Admin-configurable XP amount per activity — application code looks up
// the amount here rather than hardcoding it, so "Configure XP values" in
// the admin panel actually takes effect.
model XpRule {
  activity String @id // e.g. "MODULE_COMPLETE", "MODULE_QUIZ_PASS", "CODING_EASY", "TEST_COMPLETE", "DAILY_STREAK"
  label    String
  xp       Int
}

// One row per XP award — an append-only ledger. Total XP is SUM(xp); this
// doubles as the "Achievement History" list (activity + date + XP awarded).
model XpEvent {
  id        String   @id @default(uuid())
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  activity  String
  label     String
  xp        Int
  meta      Json?
  createdAt DateTime @default(now())

  @@index([studentId, createdAt])
}

// Badge catalog — admin-manageable (create custom badges, enable/disable). `code` drives the
// auto-award criteria in utils/gamification.js; category groups them for the Achievements page.
model Badge {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  icon        String?
  category    String // LEARNING, CODING, ASSESSMENT, CONSISTENCY, SPECIAL
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  earnedBy StudentBadge[]
}

model StudentBadge {
  id        String   @id @default(uuid())
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  badgeId   String
  earnedAt  DateTime @default(now())

  @@unique([studentId, badgeId])
  @@index([studentId])
}

// One row per student. currentStreak/longestStreak are updated lazily — only when a
// streak-eligible activity happens (solving a coding problem or completing a lesson) — not on
// a schedule. Read paths must treat currentStreak as stale (effectively 0) once lastActiveDate
// is more than a day behind "today", since nothing proactively resets it on missed days.
model StudentStreak {
  studentId      String   @id
  student        User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  currentStreak  Int      @default(0)
  longestStreak  Int      @default(0)
  lastActiveDate DateTime?
  updatedAt      DateTime @updatedAt
}

// ===================================================================
// Daily/Weekly Challenge — a LeetCode-style "problem of the day/week", drawn from the existing
// Question bank (admin schedules an existing Question onto a date, no separate authoring
// surface). Solving one routes through the same gamification hook (processGamification) and
// StudentStreak used everywhere else, so it counts toward the student's existing streak — no
// parallel streak system.
model DailyChallenge {
  id         String   @id @default(uuid())
  date       DateTime @unique // truncated to the day — "today's" challenge is looked up by date
  question   Question @relation(fields: [questionId], references: [id])
  questionId String
  createdAt  DateTime @default(now())

  submissions DailyChallengeSubmission[]

  @@index([questionId])
}

model DailyChallengeSubmission {
  id               String         @id @default(uuid())
  dailyChallenge   DailyChallenge @relation(fields: [dailyChallengeId], references: [id], onDelete: Cascade)
  dailyChallengeId String
  student          User           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId        String
  language         String
  code             String
  verdict          String   @default("PENDING")
  passedCases      Int      @default(0)
  totalCases       Int      @default(0)
  timeMs           Int?
  memoryKb         Int?
  solvedAt         DateTime? // set only once verdict becomes ACCEPTED — drives the streak/history checkmark
  updatedAt        DateTime @updatedAt

  @@unique([dailyChallengeId, studentId])
  @@index([studentId])
}

model WeeklyChallenge {
  id         String   @id @default(uuid())
  weekStart  DateTime @unique // Monday of the ISO week this challenge belongs to
  question   Question @relation(fields: [questionId], references: [id])
  questionId String
  createdAt  DateTime @default(now())

  submissions WeeklyChallengeSubmission[]

  @@index([questionId])
}

model WeeklyChallengeSubmission {
  id                String          @id @default(uuid())
  weeklyChallenge   WeeklyChallenge @relation(fields: [weeklyChallengeId], references: [id], onDelete: Cascade)
  weeklyChallengeId String
  student           User            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId         String
  language          String
  code              String
  verdict           String   @default("PENDING")
  passedCases       Int      @default(0)
  totalCases        Int      @default(0)
  timeMs            Int?
  memoryKb          Int?
  solvedAt          DateTime?
  updatedAt         DateTime @updatedAt

  @@unique([weeklyChallengeId, studentId])
  @@index([studentId])
}

// ===================================================================
// Resume Builder — one resume per student. The repeating sub-sections
// (education, skills, projects, experience, certifications, achievements,
// languages) are stored as JSON arrays rather than separate join tables:
// they have no identity or use outside their parent resume, are always
// read/written as a whole section, and this keeps "save the whole resume
// in one PATCH" simple instead of needing 7 sets of CRUD endpoints.
// ===================================================================

model Resume {
  id        String @id @default(uuid())
  student   User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String @unique

  template String @default("modern") // modern | professional | minimal | classic | software-engineer | fresher | experienced
  targetRole String? // e.g. "Java Developer" — drives role-specific keyword-gap analysis

  fullName String?
  photoUrl String? // external image URL — no in-house file storage, same constraint as Learning Module videos/PDFs
  email    String?
  mobile   String?
  linkedin String?
  github   String?
  portfolio String?
  address  String?
  summary  String?

  education      Json? // [{ degree, specialization, institution, board, startYear, endYear, score, status }]
  skills         Json? // [{ category, name, proficiency, order }]
  projects       Json? // [{ title, description, technologies, role, duration, githubUrl, liveUrl }]
  experience     Json? // [{ company, title, employmentType, startDate, endDate, responsibilities, technologies }]
  certifications Json? // [{ name, org, issueDate, expiryDate, credentialId, credentialUrl }]
  achievements   Json? // [{ category, text }]
  languages      Json? // [{ name, proficiency }]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  versions ResumeVersion[]
}

// Version history — a full snapshot of every resume field plus the ATS score at that moment,
// captured automatically on every PATCH /resume/me save (not per-keystroke; each save already
// represents one section/field-group commit in the existing editor UX). Capped at the 20 most
// recent per resume (oldest pruned on insert) to keep storage bounded — "every major edit" is
// satisfied without unbounded growth from years of iterative tweaking.
model ResumeVersion {
  id        String   @id @default(uuid())
  resume    Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  resumeId  String
  snapshot  Json     // full copy of the resume's fields at this point in time
  atsScore  Int
  createdAt DateTime @default(now())

  @@index([resumeId, createdAt])
}

// Single-row admin config: which resume sections are treated as mandatory for completion/ATS
// purposes. Seeded with sensible defaults; admins can edit via the CMS.
model ResumeFieldConfig {
  id                String   @id @default("default")
  mandatorySections Json // string[] of section keys, e.g. ["summary","education","skills","projects"]
  updatedAt         DateTime @updatedAt
}

// Lightweight admin -> student feedback notes on a resume ("Suggest improvements"), separate
// from the auto-generated ATS suggestions.
model ResumeFeedback {
  id        String   @id @default(uuid())
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  authorName String
  message   String
  createdAt DateTime @default(now())

  @@index([studentId, createdAt])
}

// ===================================================================
// Interview Prep Module. The spec describes 10 tables (interview_sessions,
// interview_questions, interview_answers, interview_reports,
// resume_analysis, coding_interviews, hr_interviews, technical_interviews,
// aptitude_interviews, mock_interviews) — consolidated here into 5 real
// models instead: HR/Technical/Coding/Aptitude are categories on ONE
// question bank and ONE session model (not 4 near-duplicate table sets),
// Mock is just a session whose questions span multiple categories, and
// Resume-based reuses the existing Resume model directly rather than a
// separate resume_analysis table (Resume already IS the analyzed,
// structured data). This is a deliberate normalization, not a missing
// feature — every category in the spec is still fully representable.
// ===================================================================

enum InterviewCategory {
  HR
  TECHNICAL
  CODING
  APTITUDE
  SYSTEM_DESIGN
  BEHAVIORAL
  MANAGERIAL
}

enum AptitudeCategory {
  QUANTITATIVE
  LOGICAL
  VERBAL
  DATA_INTERPRETATION
}

// AI-generated-content workflow status — shared by InterviewQuestionDraft and CompanyPatternNote.
// PENDING rows are never visible to students; only an explicit admin approve/reject action moves
// a row out of PENDING (see interviewDrafts.js's approve/reject routes).
enum DraftStatus {
  PENDING
  APPROVED
  REJECTED
}

// Admin-set-only labels on an already-live InterviewQuestion (see frequencyTag below) — these are
// a human's editorial judgment call at approval time, never auto-assigned by the AI generator, so
// "Trending"/"Frequently Asked" is never presented as a fabricated real-world statistic.
enum FrequencyTag {
  FREQUENTLY_ASKED
  RECENTLY_ASKED
  TRENDING
  COMPANY_SPECIFIC
}

enum PackageBand {
  LPA_3_5
  LPA_5_10
  LPA_10_20
  LPA_20_PLUS
}

enum ExperienceLevel {
  FRESHER
  EXPERIENCED
}

// Unified question bank. Which fields apply depends on `category`:
// HR/TECHNICAL use expectedKeywords+modelAnswer (free-text, heuristically
// graded); APTITUDE uses options+correctAnswer (exact-match, like a quiz);
// CODING uses starterCode+testCases+language (graded by the real judge).
// Resume-based interview questions are generated on the fly at session
// start and inserted here with `generatedForStudentId` set, so they still
// flow through the same InterviewAnswer/evaluation pipeline as bank
// questions — they just aren't reusable across students.
model InterviewQuestion {
  id                    String   @id @default(uuid())
  category              InterviewCategory
  subject               String? // Technical: "Java","Python","SQL","DBMS","OS","CN","OOP","DSA",...; Coding: topic e.g. "Arrays"
  company               String? // e.g. "TCS", "Amazon" — set only for company-specific question-bank entries; null = general pool
  aptitudeCategory       AptitudeCategory?
  difficulty            Difficulty @default(EASY)
  title                 String? // Coding: problem title — parity with Question, optional so existing prompt-only rows keep working
  prompt                String
  expectedKeywords      Json?   // HR/Technical: string[] of concepts to look for in a free-text answer
  modelAnswer           String? // HR/Technical: shown after the student answers
  options               Json?   // Aptitude: string[]
  correctAnswer         Json?   // Aptitude: correct option index
  explanation           String? // Aptitude: shown after
  starterCode           String? // Coding
  starterCodeByLanguage Json?   // Coding: { java, python, cpp, c, javascript } — preferred when present, same as Question
  testCases             Json?   // Coding: [{input, expected, isHidden?}] — isHidden absent/false = sample case
  language               String? // Coding: default language
  tags                  Json?   // Coding: string[] — parity with Question.tags

  // Coding: LeetCode-style function-only submissions — same STDIO/FUNCTION split as Question, see
  // functionHarness.js.
  evaluationType    String @default("STDIO")
  functionSignature Json?

  // "Professional structure" fields (Coding category only) — see the identically-named block on
  // Question above for the full rationale; kept in sync field-for-field.
  estimatedTimeMin   Int?
  realWorldScenario  String?
  constraints        String?
  inputFormat        String?
  outputFormat       String?
  notes              String?
  edgeCases          String?
  problemExplanation String?

  // Editorial/hints block (Coding category only) — see the identically-named block on Question
  // above for the full rationale; kept in sync field-for-field.
  hints            Json?
  timeComplexity   String?
  spaceComplexity  String?
  editorial        Json?
  similarQuestions Json?

  generatedForStudentId String? // set only for ephemeral resume-based questions
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())

  // Browse/catalog metadata for the AI-Powered Auto-Updating Mock Interview System — deliberately
  // NOT read by sanitizeQuestion() (the mid-session student payload), only by the catalog-browse
  // endpoints, so these never bleed into a live interview. frequencyTag is set by a human only,
  // at draft-approval time (see InterviewQuestionDraft below) — never auto-assigned by the AI
  // generator, so it can never be a laundered fabricated statistic.
  frequencyTag     FrequencyTag?
  packageBand      PackageBand?
  experienceLevel  ExperienceLevel?

  // Rule-based "adaptive" follow-up: when an admin links a natural next question (e.g. "Explain
  // JVM" -> "How does JVM differ from JRE?"), answering this question inserts that one as the
  // next question in the session. Deterministic and admin-authored, not a real NLU model
  // generating a follow-up from the semantic content of the answer — genuinely understanding an
  // arbitrary free-text answer well enough to ask a *good* dynamic follow-up is a real LLM
  // capability this platform doesn't have (see "no real AI anywhere" elsewhere in this file).
  followUp   InterviewQuestion?  @relation("QuestionFollowUp", fields: [followUpQuestionId], references: [id])
  followUpQuestionId String?
  followUpOf InterviewQuestion[] @relation("QuestionFollowUp")

  answers InterviewAnswer[]

  @@index([category])
  @@index([subject])
  @@index([company])
  @@index([generatedForStudentId])
  @@index([frequencyTag])
  @@index([packageBand])
  @@index([experienceLevel])
}

// AI-generated candidate question, held here — structurally separate from InterviewQuestion —
// until an admin explicitly approves it. This is a deliberate structural guarantee rather than a
// status-filter convention: pickQuestions() and every other student-facing query only ever reads
// InterviewQuestion, a table this model's rows never touch until POST /admin/drafts/questions/:id/approve
// performs an explicit create — there is no code path by which a PENDING row can reach a real
// interview session. Mirrors InterviewQuestion's own field set field-for-field so the approve step
// is a straight copy, plus the review/audit metadata below.
model InterviewQuestionDraft {
  id                    String   @id @default(uuid())
  category              InterviewCategory
  subject               String?
  company               String?
  aptitudeCategory      AptitudeCategory?
  difficulty            Difficulty @default(EASY)
  title                 String?
  prompt                String
  expectedKeywords      Json?
  modelAnswer           String?
  options               Json?
  correctAnswer         Json?
  explanation           String?
  starterCode           String?
  starterCodeByLanguage Json?
  testCases             Json?
  language              String?
  tags                  Json?

  evaluationType    String @default("STDIO")
  functionSignature Json?

  estimatedTimeMin   Int?
  realWorldScenario  String?
  constraints        String?
  inputFormat        String?
  outputFormat       String?
  notes              String?
  edgeCases          String?
  problemExplanation String?

  status            DraftStatus @default(PENDING)
  sourceRun         String?  // batch id — set when created by the Phase 5 scheduler, null for an admin-triggered one-off generate
  generatedAt       DateTime @default(now())
  reviewedByAdminId String?
  reviewedAt        DateTime?
  rejectionReason   String?
  approvedQuestionId String? // set once promoted — the resulting InterviewQuestion.id, for audit traceability

  @@index([status])
  @@index([company])
  @@index([category])
}

// AI-drafted "hiring pattern" checklist for a company+category (e.g. Amazon/CODING ->
// ["OA Questions","Interview Questions"]), same PENDING/APPROVED/REJECTED review gate as
// InterviewQuestionDraft. Only APPROVED rows are ever returned by GET /companies/:company/pattern,
// and that response is always wrapped `{ aiEstimated: true, ... }` — this is AI-estimated pattern
// commentary, never presented as verified company data.
model CompanyPatternNote {
  id                String      @id @default(uuid())
  company           String
  category          InterviewCategory
  checklistItems    Json        // string[]
  status            DraftStatus @default(PENDING)
  sourceRun         String?     // batch id — set when created by the Phase 5 scheduler, null for an admin-triggered one-off generate
  generatedAt       DateTime    @default(now())
  reviewedByAdminId String?
  reviewedAt        DateTime?

  @@index([status])
  @@index([company])
}

// One row per attempt. `category` HR/TECHNICAL/CODING/APTITUDE is a focused single-type
// session; a Mock session sets isMock=true and its questions span multiple categories
// (config.mix records the composition). Resume-based sessions set isResumeBased=true and
// their questions are the ephemeral generatedForStudentId rows created for this student.
model InterviewSession {
  id             String   @id @default(uuid())
  student        User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId      String
  category       InterviewCategory?  // null for a pure mock/company-round session spanning categories
  isMock         Boolean  @default(false)
  isResumeBased  Boolean  @default(false)
  isCompanyRound Boolean  @default(false) // HR + Technical + Coding + Managerial, all filtered by config.company
  status         String   @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED, TERMINATED (proctoring violations exceeded)
  violationCount Int      @default(0)
  terminationReason String? // e.g. "MAX_VIOLATIONS", set only when status = TERMINATED
  config         Json?    // {difficulty, subject, language, aptitudeCategory, negativeMarking, durationMin, topic, mix, company, jobRole, experienceLevel}
  startedAt      DateTime @default(now())
  submittedAt    DateTime?

  answers    InterviewAnswer[]
  report     InterviewReport?
  violations InterviewViolation[]

  @@index([studentId, category])
  @@index([studentId, status])
}

// Event-level proctoring log for interview sessions — mirrors ProctoringViolation (the module-
// coding equivalent) but kept as its own model rather than a shared polymorphic one, same
// "sibling model over a complicated shared one" call made there. `penalized` distinguishes
// events that count toward the 3-strike auto-terminate threshold (tab switch, fullscreen exit,
// camera/mic dropped) from ones that are only logged for review (face missing briefly, multiple
// faces detected — explicitly "future ready, log don't penalize" per spec).
model InterviewViolation {
  id        String   @id @default(uuid())
  session   InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String
  type      String
  penalized Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([sessionId, createdAt])
}

model InterviewAnswer {
  id           String   @id @default(uuid())
  session      InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId    String
  question     InterviewQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionId   String
  answerText   String?  // HR/Technical free-text (or Web-Speech-API transcript), or Aptitude selected option index as a string
  code         String?  // Coding
  language     String?  // Coding
  skipped      Boolean  @default(false)
  timeTakenSec Int?
  score        Int      @default(0) // 0-100, this question only
  breakdown    Json?    // category-specific sub-scores, see utils/interviewEvaluation.js
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([sessionId, questionId])
  @@index([sessionId])
}

// Finalized per-session feedback snapshot — persisted (not recomputed on every read) so a
// student's history stays stable even if scoring heuristics change later.
model InterviewReport {
  id              String   @id @default(uuid())
  session         InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId       String   @unique
  student         User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId       String
  overallScore    Int
  scoreBreakdown  Json    // e.g. {communication, confidence, vocabulary, professionalism, completeness} or {correctness, codeQuality}
  strongAreas     Json    // string[]
  weakAreas       Json    // string[]
  recommendations Json    // string[]
  createdAt       DateTime @default(now())

  @@index([studentId, createdAt])
}

model InterviewCertificate {
  id              String   @id @default(uuid())
  certificateCode String   @unique
  student         User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId       String   @unique
  averageScore    Int
  issuedAt        DateTime @default(now())
}

// ===================== Attendance Management =====================
// Institute → Department → Division → Class → Student. Department/Division are new — this
// platform's existing hierarchy was Institute → Class → Student, with no structured department
// or division concept (User.department was a free-text tag, not a relation). Both are admin-
// managed and additive: existing Class rows start with divisionId = null and remain fully
// functional for every other feature (tests, learning, etc.); a Class only needs a Division once
// an admin wants to take attendance for it.

model Department {
  id          String    @id @default(uuid())
  name        String
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  instituteId String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  divisions      Division[]
  academicGroups AcademicGroup[]

  @@unique([instituteId, name])
}

model Division {
  id           String     @id @default(uuid())
  name         String     // e.g. "A", "Division 1"
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  departmentId String
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())

  classes Class[]

  @@unique([departmentId, name])
}

// Institute -> Batch -> Department -> Section: the platform-wide replacement for Class/Division as
// the real student-grouping/enrollment mechanism. Rows are auto-created (find-or-create by the
// unique tuple below) from Bulk Upload/Registration and the one-time migration script — there is no
// manual "create a group" admin flow, mirroring the Attendance module's existing "no standalone
// entity" principle. batch/section are plain strings (no separate Batch/Section model), matching
// the existing Class.batchYear / Division.name conventions.
model AcademicGroup {
  id           String     @id @default(uuid())
  institute    Institute  @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  instituteId  String
  batch        String     // e.g. "2025-2028", or "Unassigned" for pre-migration classes with no batch
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  departmentId String
  section      String     // e.g. "Section A"
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())

  users            User[]
  testAssignments  TestAcademicGroup[]
  staffAssignments StaffClassAssignment[]

  @@unique([instituteId, batch, departmentId, section])
  @@index([instituteId])
  @@index([departmentId])
  @@index([instituteId, batch])
}

// Admin-managed: which single staff member owns attendance for a division (Class). One division =
// one staff assignment — enforced by the write route (routes/attendance.js's find-by-classId-then-
// update-or-create logic), not a DB unique constraint, so re-assigning a division to a different
// staff member updates this same row rather than creating a duplicate. Subject now lives on
// LecturePlan (entered per lecture, not fixed per assignment) since a division's teacher can cover
// multiple subjects across different lectures.
model StaffClassAssignment {
  id      String @id @default(uuid())
  staff   User   @relation("StaffClassAssignments", fields: [staffId], references: [id], onDelete: Cascade)
  staffId String
  // Legacy Class-based link — nullable so new assignments can be created via academicGroupId alone
  // once the Attendance cutover phase ships. Kept (not dropped) for existing rows' rollback safety.
  class   Class?  @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId String?
  // Institute -> Batch -> Department -> Section replacement for the class/division link above.
  academicGroup   AcademicGroup? @relation(fields: [academicGroupId], references: [id], onDelete: Cascade)
  academicGroupId String?
  // Free text (programs vary in term count/naming across institutes) — mutable; a division's
  // assignment carries across semesters and an admin can just update it rather than recreating.
  semester String @default("")

  assignedAt DateTime @default(now())

  lecturePlans LecturePlan[]

  @@index([classId])
  @@index([academicGroupId])
  @@index([staffId])
}

enum LectureType {
  REGULAR
  PRACTICE_TEST
  EXAM
}

// The "Add Plan" entity — a scheduled lecture for a division assignment, created ahead of (and
// independently from) marking attendance. lectureNumber is explicit (manually assigned or
// imported), scoped per-assignment so lectures for the same division never collide. subject is
// entered per-plan (not fixed on the assignment) since one division's teacher can cover several
// subjects across different lectures; @default("") exists only so `prisma db push` can backfill
// any plans already created before this field existed — every write path still requires a real
// value at the application layer.
model LecturePlan {
  id           String               @id @default(uuid())
  assignment   StaffClassAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  assignmentId String
  lectureNumber Int
  subject      String @default("")
  topic        String
  scheduleDate DateTime // calendar date this lecture is scheduled for (time-of-day not meaningful)
  // "Slot 1".."Slot 7" or "Other" — startTime/endTime are always stored explicitly (even for the
  // fixed slots) so the scheduled-lecture list and Excel import don't need a second lookup table.
  slotLabel    String
  startTime    String // e.g. "09:50"
  endTime      String // e.g. "10:45"
  lectureType  LectureType @default(REGULAR)
  createdBy    User     @relation("LecturePlanCreatedBy", fields: [createdById], references: [id])
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  session AttendanceSession?

  @@unique([assignmentId, lectureNumber])
  @@index([assignmentId, scheduleDate])
}

// The "Execute Attendance" record — created only once a plan's attendance is actually marked
// (1:1 with LecturePlan, hence @unique on planId). markedBy/markedAt are set once, at first save;
// updatedBy/updatedAt track every subsequent edit, giving the audit trail the Edit flow needs
// without ever losing who originally took the roll call.
model AttendanceSession {
  id          String      @id @default(uuid())
  plan        LecturePlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  planId      String      @unique
  // Only meaningful when the plan's lectureType is PRACTICE_TEST/EXAM — links this attendance to
  // the actual Test being administered, reusing the existing Test module instead of duplicating
  // exam metadata. Must be an isPublished, attendanceMandatory-enabled, currently-active Test.
  test        Test?       @relation(fields: [testId], references: [id])
  testId      String?
  markedBy    User        @relation("AttendanceMarkedBy", fields: [markedById], references: [id])
  markedById  String
  markedAt    DateTime    @default(now())
  updatedBy   User?       @relation("AttendanceUpdatedBy", fields: [updatedById], references: [id])
  updatedById String?
  updatedAt   DateTime    @updatedAt

  records AttendanceRecord[]

  @@index([testId])
}

model AttendanceRecord {
  id        String            @id @default(uuid())
  session   AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String
  student   User              @relation("AttendanceStudentRecords", fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  status    String            @default("PRESENT") // PRESENT | ABSENT | LATE | LEAVE

  @@unique([sessionId, studentId])
  @@index([studentId])
}
